# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (free database at https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret for signing session cookies — use any long random string
SESSION_SECRET=replace-with-something-random-and-long

# ── Optional ──────────────────────────────────────────────────────────────────
# Master admin username (default: admin)
ADMIN_USERNAME=admin

# Master admin password — CHANGE THIS before going live!
ADMIN_PASSWORD=admin123

# Environment (always set to production on Vercel)
NODE_ENV=production
